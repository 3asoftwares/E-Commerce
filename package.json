{
  "name": "ecommerce-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise 3A Softwares with multiple independent applications",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev:admin": "yarn workspace @e-commerce/admin-app run dev",
    "dev:shell": "yarn workspace @e-commerce/shell-app run dev",
    "dev:seller": "yarn workspace @e-commerce/seller-app run dev",
    "dev:storefront": "yarn workspace @e-commerce/storefront-app run dev",
    "dev:frontend": "concurrently \"yarn dev:admin\" \"yarn dev:seller\" \"yarn dev:shell\" \"yarn dev:storefront\" --names \"admin,seller,shell,store\" --prefix-colors \"cyan,green,yellow,blue\"",
    "service:auth": "cd services/auth-service && yarn dev",
    "service:product": "cd services/product-service && yarn dev",
    "service:order": "cd services/order-service && yarn dev",
    "service:gateway": "cd services/graphql-gateway && yarn dev",
    "dev:backend": "concurrently \"yarn service:auth\" \"yarn service:gateway\" \"yarn service:order\" \"yarn service:product\" --names \"auth,gateway,order,product\" --prefix-colors \"magenta,green,yellow,cyan\"",
    "dev:storybook": "yarn workspace @e-commerce/ui-library run storybook",
    "dev:all": "concurrently \"yarn dev:backend\" \"yarn dev:frontend\" \"yarn dev:storybook\" --names \"BACKEND,FRONTEND,UI\" --prefix-colors \"magenta,cyan,cyan\"",
    "build:admin": "yarn workspace @e-commerce/admin-app run build",
    "build:shell": "yarn workspace @e-commerce/shell-app run build",
    "build:seller": "yarn workspace @e-commerce/seller-app run build",
    "build:storefront": "yarn workspace @e-commerce/storefront-app run build",
    "build:frontend": "yarn build:shell && yarn build:admin && yarn build:seller && yarn build:storefront",
    "build:auth": "cd services/auth-service && yarn build",
    "build:product": "cd services/product-service && yarn build",
    "build:order": "cd services/order-service && yarn build",
    "build:gateway": "cd services/graphql-gateway && yarn build",
    "build:backend": "yarn build:auth && yarn build:product && yarn build:order && yarn build:gateway",
    "build:utils": "yarn workspace @e-commerce/utils run build",
    "build:storybook": "yarn workspace @e-commerce/ui-library run build",
    "build:all": "yarn build:shell && yarn build:admin && yarn build:seller && yarn build:storefront && yarn build:auth && yarn build:product && yarn build:order && yarn build:gateway"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "npm-run-all": "^4.1.5"
  },
  "resolutions": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "e-commerce",
    "monorepo",
    "react",
    "nextjs",
    "vite",
    "webpack"
  ],
  "author": "",
  "license": "ISC"
}
