{
  "//": "Auth Service TypeScript Configuration",
  "extends": "../../packages/utils/src/config/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "src",
    "outDir": "dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "paths": {
      "@controllers/*": ["controllers/*"],
      "@use-cases/*": ["use-cases/*"],
      "@domain/*": ["domain/*"],
      "@infrastructure/*": ["infrastructure/*"],
      "@middleware/*": ["middleware/*"],
      "@routes/*": ["routes/*"],
      "@config/*": ["config/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
